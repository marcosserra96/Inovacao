# URL e chave pública (anon) do projeto Supabase.
# Encontre em: Supabase Dashboard > Project Settings > API
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=SUA_CHAVE_ANON_PUBLICA

# Nome padrão do evento, usado antes de qualquer configuração no admin.
VITE_DEFAULT_EVENT_NAME="Dinâmica de Inovação"

# E-mail do usuário administrativo criado no Supabase Auth (ver README).
# O login do painel pede só a senha — este e-mail é usado por baixo dos panos.
VITE_ADMIN_EMAIL="admin@seu-evento.com"
